# Copiază acest fișier ca .env (fără ".example") și completează valorile reale.
# Niciodată nu commit-ui .env în git!

# PostgreSQL — completează parola pe care o setezi la instalare
DATABASE_URL="postgresql://postgres:PAROLA_TA@localhost:5432/notite_platform?schema=public"

# Generează un string random lung. Pe Linux/Mac: openssl rand -base64 64
# Pe Windows poți folosi: https://generate-secret.vercel.app/64
JWT_SECRET="schimba-cu-un-string-random-lung-de-minim-64-caractere"

PORT=3000
NODE_ENV=development

# URL-ul frontendului (folosit la generarea linkurilor de verificare email)
FRONTEND_URL=http://localhost:5173

# SMTP pentru trimiterea email-urilor de verificare (opțional).
# Adresa "From" se setează în Admin → Sistem (head admin only).
# Dacă nu configurezi SMTP, head adminul nu poate activa verificarea email.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tu@gmail.com
SMTP_PASS=parola-de-aplicatie

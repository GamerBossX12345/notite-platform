// Schema bazei de date.
// Modificările aici se aplică prin: npm run prisma:migrate
// Studio (UI vizual pentru DB): npm run prisma:studio

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  username     String   @unique
  passwordHash String
  name         String?
  school       String?
  grade        Int?
  bio          String?
  reputation   Int      @default(0)
  createdAt    DateTime @default(now())

  notes    Note[]
  ratings  Rating[]
  comments Comment[]
  reports  Report[]
}

model Note {
  id         String   @id @default(uuid())
  authorId   String
  author     User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  title      String
  subject    String
  gradeLevel Int
  chapter    String?
  type       NoteType

  content    Json?
  fileUrl    String?

  // Câmpuri denormalizate — actualizate într-o tranzacție când se votează.
  // Alternativă: AVG/COUNT pe tabela Rating la fiecare listare. Mai lent.
  avgRating   Float @default(0)
  ratingCount Int   @default(0)
  viewCount   Int   @default(0)

  // Fingerprint pentru detectorul de duplicate (vine în pasul 10).
  contentHash String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ratings  Rating[]
  comments Comment[]
  reports  Report[]

  @@index([subject, gradeLevel])
  @@index([authorId])
}

enum NoteType {
  REZUMAT
  EXERCITII
  FISA
  HARTA_CONCEPTUALA
}

model Rating {
  id        String   @id @default(uuid())
  userId    String
  noteId    String
  value     Int
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  note Note @relation(fields: [noteId], references: [id], onDelete: Cascade)

  // Garanție la nivel de DB: un user nu poate vota de 2 ori aceeași notiță.
  @@unique([userId, noteId])
}

model Comment {
  id        String   @id @default(uuid())
  userId    String
  noteId    String
  content   String
  parentId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  note    Note      @relation(fields: [noteId], references: [id], onDelete: Cascade)
  parent  Comment?  @relation("CommentThread", fields: [parentId], references: [id], onDelete: Cascade)
  replies Comment[] @relation("CommentThread")
}

model Report {
  id         String       @id @default(uuid())
  reporterId String
  noteId     String
  reason     ReportReason
  details    String?
  status     ReportStatus @default(PENDING)
  createdAt  DateTime     @default(now())

  reporter User @relation(fields: [reporterId], references: [id])
  note     Note @relation(fields: [noteId], references: [id], onDelete: Cascade)
}

enum ReportReason {
  PLAGIAT
  CONTINUT_NEPOTRIVIT
  SPAM
  ALTUL
}

enum ReportStatus {
  PENDING
  REVIEWED
  RESOLVED
}
